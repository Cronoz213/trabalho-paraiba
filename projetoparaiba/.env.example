# Copie este arquivo para .env e preencha os valores
DJANGO_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=seuusuario.pythonanywhere.com

# Deixe em branco para usar SQLite (recomendado no PythonAnywhere gratuito)
DATABASE_URL=

# Chave Gemini — informe em tempo de execução, NÃO commite aqui
GEMINI_API_KEY=
